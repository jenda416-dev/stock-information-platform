{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "cd /Users/alexchen/Desktop/Coding Chicken/stock-dashboard && npx tsc --noEmit || echo '{\"continue\":false,\"stopReason\":\"TypeScript 型別檢查失敗，請修正後再 commit\"}'",
            "timeout": 60,
            "statusMessage": "TypeScript 型別檢查中..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm --version)",
      "Bash(bun --version)",
      "Bash(npx create-next-app@latest . --typescript --tailwind --app --no-src-dir --import-alias \"@/*\" --no-eslint)",
      "Bash(npx create-next-app@latest . --typescript --tailwind --app --no-src-dir --import-alias \"@/*\" --no-eslint --use-npm)",
      "Bash(npx create-next-app@latest . --typescript --tailwind --app --no-src-dir --import-alias \"@/*\" --no-eslint --use-npm --yes)",
      "Bash(npm install:*)",
      "Bash(curl -s http://localhost:3000)",
      "Bash(npx tsc:*)",
      "Bash(npx tsx --env-file=.env.local -e \":*)",
      "Bash(npx tsx:*)",
      "Bash(open http://localhost:3000)",
      "Bash(source /Users/alexchen/Desktop/Coding Chicken/stock-dashboard/.env.local)",
      "Bash(curl -s \"https://api.clerk.com/v1/users?email_address=jenda416@gmail.com\" -H \"Authorization: Bearer $CLERK_SECRET_KEY\")",
      "Bash(npx vercel:*)",
      "Bash(npm run:*)"
    ]
  }
}
